FROM golang:1.22-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download 2>/dev/null || true
COPY . .
RUN CGO_ENABLED=0 go build -o multiplexer cmd/multiplexer/main.go

FROM alpine:latest
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=builder /app/multiplexer /app/multiplexer
RUN chmod +x /app/multiplexer
EXPOSE 8080
CMD ["/app/multiplexer"]
